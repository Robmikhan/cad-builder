# Server
CAD_AGENT_HOST=0.0.0.0
CAD_AGENT_PORT=8080
CAD_AGENT_DATA_DIR=data

# Authentication (comma-separated API keys; empty = no auth / local dev mode)
CAD_AGENT_API_KEYS=

# CORS origins (comma-separated; default = *)
CAD_AGENT_CORS_ORIGINS=*

# Rate limiting
CAD_AGENT_RATE_LIMIT=60
CAD_AGENT_RATE_WINDOW_SEC=60

# LLM — Ollama (local, default)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Supabase (optional persistence)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_BUCKET=cad-bundles

# Model cache
HF_HOME=data/cache/hf
CAD_AGENT_CACHE_DIR=data/cache

# Limits
CAD_AGENT_MAX_REPAIR_ITERS=3
CAD_AGENT_STEP_TIMEOUT_SEC=30
CAD_AGENT_CAD_TIMEOUT_SEC=30

# Logging
CAD_AGENT_LOG_LEVEL=INFO
