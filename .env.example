# Server
CAD_AGENT_HOST=0.0.0.0
CAD_AGENT_PORT=8080
CAD_AGENT_DATA_DIR=data

# LLM (optional orchestration)
LLM_PROVIDER=none
LLM_MODEL=
LLM_API_KEY=

# Supabase (optional persistence)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_BUCKET=cad-bundles

# Model cache
HF_HOME=data/cache/hf
CAD_AGENT_CACHE_DIR=data/cache

# Limits
CAD_AGENT_MAX_REPAIR_ITERS=5
CAD_AGENT_STEP_TIMEOUT_SEC=30
CAD_AGENT_CAD_TIMEOUT_SEC=30

# Logging
CAD_AGENT_LOG_LEVEL=INFO
