# ── CAD Builder Production Environment ──
# Copy this to .env on your server and fill in the values

# Server
CAD_AGENT_HOST=0.0.0.0
CAD_AGENT_PORT=8080
CAD_AGENT_DATA_DIR=data

# Domain (used by Caddy for auto-SSL)
DOMAIN=localhost

# Authentication — REQUIRED in production
# Generate keys with: python -c "import secrets; print(f'cad_admin_{secrets.token_hex(16)}')"
CAD_AGENT_API_KEYS=

# CORS (set to your domain in production)
CAD_AGENT_CORS_ORIGINS=*

# Stripe Payment Links (paste from Stripe Dashboard)
STRIPE_LINK_STARTER=
STRIPE_LINK_PRO=
STRIPE_LINK_BUSINESS=

# Rate Limiting
CAD_AGENT_RATE_LIMIT=60
CAD_AGENT_RATE_WINDOW_SEC=60

# LLM — Ollama (runs as Docker service in production)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# CadQuery sandbox timeout
CAD_AGENT_CAD_TIMEOUT_SEC=120

# Supabase (optional — local JSON persistence works fine)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=cad-bundles
